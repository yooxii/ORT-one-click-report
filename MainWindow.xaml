<Window x:Class="ORT一键报告.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="ORT一键报告" Height="640" Width="1100" MinHeight="400" MinWidth="600" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!--Create list of enumeration values-->
        <ObjectDataProvider x:Key="RpstatusEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type Type="local:ReportStatus"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Menu x:Name="_Menu" Grid.Row="0">
            <MenuItem Header="文件">
                <MenuItem Header="新建"/>
                <MenuItem Header="打开"/>
            </MenuItem>
            <MenuItem Header="选项">
                <MenuItem Header="重置"/>
                <MenuItem Header="设置"/>
            </MenuItem>
            <MenuItem Header="ATE数据" Click="MenuItem_ATE_Click"/>
            <MenuItem Header="帮助"/>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid Height="30" VerticalAlignment="Top" Margin="10,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="65*" MaxWidth="65" MinWidth="65"/>
                        <ColumnDefinition Width="650*" MinWidth="200"/>
                        <ColumnDefinition Width="65*" MinWidth="65"/>
                        <ColumnDefinition Width="65*" MinWidth="65"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="报告路径"/>
                    <TextBox x:Name="text_rootReportPath" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="WrapWithOverflow" ToolTip="点击浏览来选择"/>
                    <Button x:Name="btn_rootpath_t" Content="浏览" Cursor="Hand" Click="btn_rootReportPath_Click" Margin="3,0,3,0" Grid.Column="2"/>
                    <Button x:Name="btn_readReport_t" Content="一键报告" Cursor="Hand" Click="DoReport_Click" Margin="3,0,3,0" Grid.Column="3"/>
                </Grid>
            </Grid>
            <TabControl Margin="10,3,10,3" Grid.Row="1" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <TabItem Header="Thermal Shock">
                    <local:BaseReportPage x:Name="thermalshockPage" ReportType="Thermal Shock" TestTime="1"/>
                </TabItem>
                <TabItem Header="Burn In">
                    <local:BaseReportPage x:Name="burninPage" ReportType="Burn In" TestTime="7"/>
                </TabItem>
                <TabItem Header="EMI">
                    <ScrollViewer>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <local:ReportHeaderWidget x:Name="e_ReportHeader" TestTime="1"/>
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Content="模板路径:" Margin="3" VerticalContentAlignment="Center"/>
                                        <TextBox x:Name="e_TemplatePath_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        <Button x:Name="btnTemplatePath" Content="选择" Width="70" Grid.Column="2" Margin="3"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Content="数据路径:" Margin="3" VerticalContentAlignment="Center"/>
                                        <TextBox x:Name="e_DataPath_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        <Button x:Name="btnDataPath" Content="选择" Width="70" Grid.Column="2" Margin="3"/>
                                        <Button x:Name="btnToPDF" Content="转PDF" Width="70" Grid.Column="3" Margin="3"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="负载数量:" Margin="3" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="e_LoadCount_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        </Grid>
                                        <Grid Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="周期:" Margin="3" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="e_DC_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        </Grid>
                                        <Grid Grid.Column="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="版本:" Margin="3" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="e_Version_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        </Grid>
                                        <Grid Grid.Column="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="工令:" Margin="3" VerticalContentAlignment="Center"/>
                                            <TextBox x:Name="e_WorkerNo_text" Grid.Column="1" VerticalContentAlignment="Center" TextWrapping="Wrap" Margin="3"/>
                                        </Grid>
                                        <Button x:Name="btnReadPath" Content="读取" Width="70" Grid.Column="5" Margin="3"/>
                                    </Grid>
                                </StackPanel>
                                <local:ReportPicturesWidget x:Name="widget_pic_e"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"  Grid.Row="1">
                                <Button Content="重置" Margin="5" MinWidth="120" Grid.Column="1"  Cursor="Hand" Click="Info_Set_Click"/>
                                <Button Tag="emi" Content="完成" Click="btn_finish_Click" Margin="5"  MinWidth="120" Cursor="Hand" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
        <StatusBar Grid.Row="2" Margin="5,0,5,0" Visibility="Collapsed">
            <StatusBarItem x:Name="StatusBarMsg" Content="请选择"/>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar x:Name="StatusProgressBar" IsIndeterminate="True" Width="400" Height="15" Visibility="Hidden"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
