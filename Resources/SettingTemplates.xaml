<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:ORT一键报告.ViewModels"
                    xmlns:conv="clr-namespace:ORT一键报告.Converters">

    <!-- 字符串输入框 -->
    <DataTemplate x:Key="StringTemplate" DataType="{x:Type vm:SettingItemViewModel}">
        <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Padding="4" MinWidth="150"/>
    </DataTemplate>

    <!-- 布尔开关 -->
    <DataTemplate x:Key="BoolTemplate" DataType="{x:Type vm:SettingItemViewModel}">
        <CheckBox Content="{Binding Label}" IsChecked="{Binding Value}" Margin="0,5"/>
    </DataTemplate>

    <!-- 下拉框 -->
    <DataTemplate x:Key="ComboTemplate" DataType="{x:Type vm:SettingItemViewModel}">
        <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedItem="{Binding Value}" Padding="4"/>
    </DataTemplate>

    <DataTemplate x:Key="GroupTemplate" DataType="{x:Type vm:SettingItemViewModel}">
    </DataTemplate>

    <conv:SettingTemplateSelector x:Key="SettingSelector"
            StringTemplate="{StaticResource StringTemplate}"
            BoolTemplate="{StaticResource BoolTemplate}"
            ComboTemplate="{StaticResource ComboTemplate}"
            GroupTemplate="{StaticResource GroupTemplate}"/>
    
</ResourceDictionary>