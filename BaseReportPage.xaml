<UserControl x:Class="ORT一键报告.BaseReportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ORT一键报告"
             mc:Ignorable="d" 
             x:Name="root"
             d:DesignHeight="750" d:DesignWidth="800">
    <Grid>
        <ScrollViewer>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="180*"/>
                    <RowDefinition Height="90*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.RowSpan="2">
                    <local:ReportHeaderWidget x:Name="ReportHeader" TestTime="{Binding TestTime, ElementName=root}"/>
                    <local:ReportPicturesWidget x:Name="widget_pic"/>
                    <local:UserResultDataGrid x:Name="details_data" Grid.Row="1"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Label Content="ATE数据"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="Gray" BorderThickness="1" Margin="3" CornerRadius="1">
                                <TextBlock x:Name="ATEDatas_text" Text="请点击右侧按钮选择ATE数据文件" TextWrapping="Wrap" Margin="3"/>
                            </Border>
                            <Button x:Name="btn_ATEDatas" Tag="ATEDatas_text" Grid.Column="1" Content="浏览" Margin="3" Click="btn_ATEDatas_Click"/>
                        </Grid>
                    </Grid>

                    <Border BorderBrush="Black" BorderThickness="1" Height="1" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="重置" Margin="5" MinWidth="120" Cursor="Hand" Click="Info_Set_Click"/>
                    <Button Tag="{Binding ReportType, ElementName=root}" Content="完成" Click="btn_finish_Click" Margin="5" MinWidth="120" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
