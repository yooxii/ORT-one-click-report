<Window x:Class="ORT一键报告.ATEWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告"
        mc:Ignorable="d"
        Title="ATE数据制作" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="25"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Menu VerticalContentAlignment="Center">
            <MenuItem Header="打开" Click="OpenATEDatas_Click"/>
            <MenuItem Header="制作" Click="MakeATEReport_Click"/>
            <MenuItem Header="另存为" Click="SaveATEDatas_Click"/>
            <MenuItem Header="退出" Click="Close_Click"/>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Label Content="ATE模板" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="text_ATETemplate" Text="请选择" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,3,0,3"/>
            <Button x:Name="btn_ATETemplate" Content="浏览" Grid.Column="2" Margin="3" Click="btn_ATETemplate_Click"/>
        </Grid>
        <Grid Grid.Row="2" Margin="3">
            <DataGrid x:Name="dataGridATE" CanUserAddRows="False">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                </DataGrid.Resources>
            </DataGrid>
        </Grid>
        <WrapPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" ItemHeight="25" ItemWidth="90">
            <Button x:Name="btn_reread" Content="重新读取" Click="btn_reread_Click"/>
            <Separator Width="30" Background="Transparent"/>
            <Button x:Name="btn_save" Content="另存为" Click="SaveATEDatas_Click"/>
            <Separator Width="30" Background="Transparent"/>
            <Button x:Name="btn_quit" Content="退出" Click="Close_Click"/>
        </WrapPanel>
    </Grid>
</Window>
