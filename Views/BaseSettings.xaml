<UserControl x:Class="ORT一键报告.BaseSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ORT一键报告"
             xmlns:vm="clr-namespace:ORT一键报告.ViewModels"
             xmlns:conv="clr-namespace:ORT一键报告.Converters"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="15">
        <ItemsControl ItemsSource="{Binding RootItems}">
            <ItemsControl.ItemTemplateSelector>
                <conv:SettingTemplateSelector 
                    StringTemplate="{StaticResource StringTemplate}"
                    BoolTemplate="{StaticResource BoolTemplate}"
                    ComboTemplate="{StaticResource ComboTemplate}"/>
            </ItemsControl.ItemTemplateSelector>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
