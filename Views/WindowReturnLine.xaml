<Window x:Class="ORT一键报告.Views.WindowReturnLine"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告.Views"
        xmlns:viewmodels="clr-namespace:ORT一键报告.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:ReturnLineViewModel}"
        mc:Ignorable="d"
        Title="单体回线转移单" Height="450" Width="800">
    <Window.Resources>
        
    </Window.Resources>
    <Grid Margin="25">
        <Border BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="领退表单路径:" VerticalAlignment="Center"/>
                    <TextBox x:Name="textbox_lt" TextWrapping="Wrap" Text="{Binding LTPath}" Grid.Column="1" Margin="3"/>
                    <Button x:Name="btn_lt" Grid.Column="2" Margin="3" Content="浏览" Command="{Binding SelectLTPathCommand}"/>
                </Grid>
                <Expander Header="筛选" Grid.Row="1" IsExpanded="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="领用日期:" VerticalContentAlignment="Center"/>
                            <DatePicker Grid.Column="1" Margin="3" SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="~" Grid.Column="2" VerticalContentAlignment="Center"/>
                            <DatePicker Grid.Column="3" Margin="3" SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="RT工令:" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="1" Margin="3" Text="{Binding StartRTAH, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="~" Grid.Column="2" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="3" Margin="3" Text="{Binding EndRTAH, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                        <Button Grid.Column="2" Margin="3" Content="确定"/>
                    </Grid>
                </Expander>
                <GroupBox Header="预览" Grid.Row="2">
                    <StackPanel>
                        <TextBlock Text="请检查表单路径和筛选条件是否正确" HorizontalAlignment="Center" Visibility="Collapsed"/>
                        <local:UserControlReturnLineSingle Visibility="Visible"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>
    </Grid>
</Window>
