<Window x:Class="ORT一键报告.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告"
        Title="{Binding Title}" Height="200" Width="400" FontSize="14" WindowStartupLocation="CenterOwner" WindowStyle="ToolWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock x:Name="IconText" VerticalAlignment="Top" Margin="0,3,10,0"/>
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" VerticalAlignment="Center"/>
        </StackPanel>
        <WrapPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2" Margin="0,15,0,0">
        </WrapPanel>
    </Grid>
</Window>
