<Window x:Class="ORT一键报告.EMIReportSetup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告"
        xmlns:viewmodels="clr-namespace:ORT一键报告.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:EMISetupViewModel}"
        mc:Ignorable="d"
        Title="EMIReportSetup" Height="450" Width="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Menu Margin="3,0,0,3">
            <MenuItem Header="重新加载" Command="{Binding LoadFromExcelCommand}"/>
            <MenuItem Header="保存设置" Command="{Binding SaveSettingsCommand}"/>
        </Menu>
        <local:BaseSettings Grid.Row="1"/>
    </Grid>
</Window>
