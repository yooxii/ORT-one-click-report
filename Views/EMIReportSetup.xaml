<Window x:Class="ORT一键报告.EMIReportSetup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ORT一键报告" xmlns:viewmodels="clr-namespace:ORT一键报告.ViewModels"
        d:DataContext="{d:DesignInstance Type=viewmodels:EMIViewModel}"
        mc:Ignorable="d"
        Title="EMIReportSetup" Height="450" Width="400">
    <Window.Resources>
        <!-- 当数据是 TextField 时，自动渲染为 TextBox -->
        <DataTemplate DataType="{x:Type local:TextField}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="{Binding Label}" Width="80" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Value}" Width="200"/>
            </StackPanel>
        </DataTemplate>

        <!-- 当数据是 SwitchField 时，自动渲染为 CheckBox -->
        <DataTemplate DataType="{x:Type local:SwitchField}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="{Binding Label}" Width="80" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding IsChecked}" Content="是否开启"/>
            </StackPanel>
        </DataTemplate>

        <!-- 当数据是 OptionField 时，自动渲染为 ComboBox -->
        <DataTemplate DataType="{x:Type local:OptionField}">
            <StackPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="{Binding Label}" Width="80" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Options}" 
                          SelectedItem="{Binding SelectedOption}" 
                          Width="200"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <StackPanel Margin="10" Orientation="Horizontal" Height="30">
                <Button Content="从Excel加载" Margin="0, 0, 10, 0" Padding="10, 5, 10, 5" Command="{Binding LoadFromExcelCommand}"/>
                <Button Content="保存设置" Margin="0, 0, 10, 0" Padding="10, 5, 10, 5" Command="{Binding SaveSettingsCommand}"/>
            </StackPanel>
            <Grid Grid.Row="1">
                <ItemsControl ItemsSource="{Binding EMISetupFields}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
